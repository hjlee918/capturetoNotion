{
  "manifest_version": 3,
  "name": "Notion Capture",
  "version": "0.1.0",
  "description": "Save page content into Notion with form templates.",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}